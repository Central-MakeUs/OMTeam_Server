# OMT Server 환경 변수 템플릿
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.
# cp .env.example .env

# ===========================================
# 환경 설정
# ===========================================
SPRING_PROFILES_ACTIVE=local

# ===========================================
# 데이터베이스
# ===========================================
SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/omt_local_db?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password

# ===========================================
# Redis
# ===========================================
SPRING_DATA_REDIS_HOST=omt-redis
SPRING_DATA_REDIS_PORT=6379

# ===========================================
# JWT
# ===========================================
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_ACCESS_EXPIRE=300
JWT_REFRESH_EXPIRE=1209600

# ===========================================
# OAuth
# ===========================================
OAUTH_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com
OAUTH_KAKAO_CLIENT_ID=your-kakao-client-id
OAUTH_APPLE_CLIENT_ID=your-apple-bundle-id

# ===========================================
# AI Server
# ===========================================
AI_SERVER_BASE_URL=http://omt-ai:8000
ANTHROPIC_API_KEY=sk-ant-xxxxx
UPSTAGE_API_KEY=up_xxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
LANGFUSE_HOST=https://cloud.langfuse.com
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_xxxxx
LANGSMITH_PROJECT=your-langsmith-project

# ===========================================
# 배포 전용 (ECR)
# ===========================================
# ECR_REGISTRY=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com
# IMAGE_TAG=latest
